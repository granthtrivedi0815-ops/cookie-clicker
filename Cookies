<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🍪 Mega Cookie Clicker</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    .stars {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      background-image: 
        radial-gradient(2px 2px at 20px 30px, #eee, transparent),
        radial-gradient(2px 2px at 40px 70px, #fff, transparent),
        radial-gradient(1px 1px at 90px 40px, #ddd, transparent),
        radial-gradient(2px 2px at 160px 120px, #fff, transparent),
        radial-gradient(1px 1px at 230px 80px, #eee, transparent),
        radial-gradient(2px 2px at 300px 150px, #fff, transparent),
        radial-gradient(1px 1px at 370px 50px, #ddd, transparent),
        radial-gradient(2px 2px at 450px 180px, #fff, transparent);
      background-size: 500px 200px;
      animation: twinkle 5s ease-in-out infinite;
    }

    @keyframes twinkle {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }

    .container {
      text-align: center;
      z-index: 10;
    }

    h1 {
      color: #ffd700;
      font-size: 2.5rem;
      margin-bottom: 10px;
      text-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
      animation: glow 2s ease-in-out infinite alternate;
    }

    @keyframes glow {
      from { text-shadow: 0 0 20px rgba(255, 215, 0, 0.5); }
      to { text-shadow: 0 0 40px rgba(255, 215, 0, 0.8), 0 0 60px rgba(255, 215, 0, 0.4); }
    }

    .cookie-counter {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 20px 40px;
      margin-bottom: 30px;
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .count {
      font-size: 1.8rem;
      color: #fff;
      font-weight: bold;
    }

    .count-number {
      color: #ffd700;
      font-size: 2.2rem;
    }

    .label {
      color: rgba(255, 255, 255, 0.7);
      font-size: 1rem;
      margin-top: 5px;
    }

    .per-click {
      color: #4ade80;
      font-size: 0.9rem;
      margin-top: 10px;
    }

    .cookie-btn {
      width: 250px;
      height: 250px;
      border-radius: 50%;
      border: none;
      cursor: pointer;
      position: relative;
      background: radial-gradient(circle at 30% 30%, #d4a056 0%, #c4873d 40%, #8b5a2b 100%);
      box-shadow: 
        0 10px 30px rgba(0, 0, 0, 0.4),
        inset 0 -10px 30px rgba(0, 0, 0, 0.3),
        inset 0 10px 30px rgba(255, 255, 255, 0.2);
      transition: transform 0.1s ease, box-shadow 0.1s ease;
      animation: float 3s ease-in-out infinite;
    }

    .cookie-btn:hover {
      transform: scale(1.05);
      box-shadow: 
        0 15px 40px rgba(255, 215, 0, 0.3),
        inset 0 -10px 30px rgba(0, 0, 0, 0.3),
        inset 0 10px 30px rgba(255, 255, 255, 0.2);
    }

    .cookie-btn:active {
      transform: scale(0.95);
      animation: none;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .chip {
      position: absolute;
      width: 25px;
      height: 20px;
      background: radial-gradient(circle at 40% 40%, #5c3d2e 0%, #3d2518 100%);
      border-radius: 50%;
      box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.5);
    }

    .chip:nth-child(1) { top: 40px; left: 60px; }
    .chip:nth-child(2) { top: 70px; left: 150px; width: 30px; height: 25px; }
    .chip:nth-child(3) { top: 120px; left: 80px; width: 22px; height: 18px; }
    .chip:nth-child(4) { top: 100px; left: 170px; }
    .chip:nth-child(5) { top: 160px; left: 120px; width: 28px; height: 22px; }
    .chip:nth-child(6) { top: 180px; left: 60px; width: 20px; height: 16px; }
    .chip:nth-child(7) { top: 60px; left: 100px; width: 18px; height: 15px; }

    .click-effect {
      position: fixed;
      pointer-events: none;
      font-size: 1.5rem;
      font-weight: bold;
      color: #ffd700;
      text-shadow: 0 0 10px rgba(255, 215, 0, 0.8);
      animation: floatUp 1s ease-out forwards;
      z-index: 1000;
    }

    @keyframes floatUp {
      0% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
      100% {
        opacity: 0;
        transform: translateY(-100px) scale(1.5);
      }
    }

    .mini-cookie {
      position: fixed;
      font-size: 2rem;
      pointer-events: none;
      animation: scatter 1s ease-out forwards;
      z-index: 999;
    }

    @keyframes scatter {
      0% {
        opacity: 1;
        transform: translate(0, 0) rotate(0deg) scale(1);
      }
      100% {
        opacity: 0;
        transform: translate(var(--tx), var(--ty)) rotate(720deg) scale(0);
      }
    }

    .stats {
      margin-top: 30px;
      display: flex;
      gap: 20px;
    }

    .stat-box {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 15px;
      padding: 15px 25px;
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .stat-label {
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .stat-value {
      color: #fff;
      font-size: 1.3rem;
      font-weight: bold;
      margin-top: 5px;
    }

    .reset-btn {
      margin-top: 30px;
      padding: 12px 30px;
      background: linear-gradient(135deg, #e74c3c, #c0392b);
      color: white;
      border: none;
      border-radius: 25px;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .reset-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 5px 20px rgba(231, 76, 60, 0.4);
    }
  </style>
</head>
<body>
  <div class="stars"></div>
  
  <div class="container">
    <h1>🍪 Mega Cookie Clicker</h1>
    
    <div class="cookie-counter">
      <div class="count">
        <span class="count-number" id="cookieCount">0</span>
      </div>
      <div class="label">cookies</div>
      <div class="per-click">+10,000,000,000,000,000,000 per click!</div>
    </div>
    
    <button class="cookie-btn" id="cookieBtn" aria-label="Click for cookies">
      <div class="chip"></div>
      <div class="chip"></div>
      <div class="chip"></div>
      <div class="chip"></div>
      <div class="chip"></div>
      <div class="chip"></div>
      <div class="chip"></div>
    </button>
    
    <div class="stats">
      <div class="stat-box">
        <div class="stat-label">Total Clicks</div>
        <div class="stat-value" id="totalClicks">0</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Cookies/Click</div>
        <div class="stat-value">10 Quintillion</div>
      </div>
    </div>
    
    <button class="reset-btn" id="resetBtn">🔄 Reset Game</button>
  </div>

  <script>
    const cookiesPerClick = BigInt('10000000000000000000');
    let cookies = BigInt(0);
    let totalClicks = 0;
    
    const cookieCount = document.getElementById('cookieCount');
    const totalClicksEl = document.getElementById('totalClicks');
    const cookieBtn = document.getElementById('cookieBtn');
    const resetBtn = document.getElementById('resetBtn');
    
    function formatBigNumber(n) {
      const str = n.toString();
      const len = str.length;
      
      if (len <= 6) return Number(n).toLocaleString();
      
      const suffixes = [
        '', 'thousand', 'million', 'billion', 'trillion', 
        'quadrillion', 'quintillion', 'sextillion', 'septillion',
        'octillion', 'nonillion', 'decillion', 'undecillion',
        'duodecillion', 'tredecillion', 'quattuordecillion'
      ];
      
      const suffixIndex = Math.floor((len - 1) / 3);
      
      if (suffixIndex >= suffixes.length) {
        return str.slice(0, 3) + '.' + str.slice(3, 5) + 'e' + (len - 1);
      }
      
      const divisorLen = suffixIndex * 3;
      const wholePart = str.slice(0, len - divisorLen);
      const decimalPart = str.slice(len - divisorLen, len - divisorLen + 2);
      
      if (decimalPart && parseInt(decimalPart) > 0) {
        return `${wholePart}.${decimalPart} ${suffixes[suffixIndex]}`;
      }
      return `${wholePart} ${suffixes[suffixIndex]}`;
    }
    
    function createClickEffect(x, y) {
      const effect = document.createElement('div');
      effect.className = 'click-effect';
      effect.textContent = '+10 Quintillion!';
      effect.style.left = x + 'px';
      effect.style.top = y + 'px';
      document.body.appendChild(effect);
      
      setTimeout(() => effect.remove(), 1000);
    }
    
    function createMiniCookies(x, y) {
      for (let i = 0; i < 8; i++) {
        const cookie = document.createElement('div');
        cookie.className = 'mini-cookie';
        cookie.textContent = '🍪';
        cookie.style.left = x + 'px';
        cookie.style.top = y + 'px';
        
        const angle = (i / 8) * Math.PI * 2;
        const distance = 80 + Math.random() * 60;
        cookie.style.setProperty('--tx', `${Math.cos(angle) * distance}px`);
        cookie.style.setProperty('--ty', `${Math.sin(angle) * distance}px`);
        
        document.body.appendChild(cookie);
        setTimeout(() => cookie.remove(), 1000);
      }
    }
    
    function handleClick(e) {
      cookies += cookiesPerClick;
      totalClicks++;
      
      cookieCount.textContent = formatBigNumber(cookies);
      totalClicksEl.textContent = totalClicks.toLocaleString();
      
      const rect = cookieBtn.getBoundingClientRect();
      const x = rect.left + rect.width / 2;
      const y = rect.top;
      
      createClickEffect(x, y);
      createMiniCookies(e.clientX, e.clientY);
    }
    
    function resetGame() {
      cookies = BigInt(0);
      totalClicks = 0;
      cookieCount.textContent = '0';
      totalClicksEl.textContent = '0';
    }
    
    cookieBtn.addEventListener('click', handleClick);
    resetBtn.addEventListener('click', resetGame);
  </script>
</body>
</html>
