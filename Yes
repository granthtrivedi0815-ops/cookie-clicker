<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hollow Knight Quiz</title>
    <style>
        body {
            background-color: #0b1116;
            color: #d1d9e0;
            font-family: 'Georgia', serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }
        .quiz-container {
            background-color: #161f26;
            padding: 30px;
            border-radius: 8px;
            border: 2px solid #3a4d5c;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }
        h1 {
            color: #e2f0fd;
            text-align: center;
            font-size: 24px;
            margin-top: 0;
            border-bottom: 1px solid #3a4d5c;
            padding-bottom: 10px;
        }
        .question {
            font-size: 18px;
            margin-bottom: 20px;
            display: none;
        }
        .question.active {
            display: block;
        }
        .options {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        button {
            background-color: #202f3b;
            color: #d1d9e0;
            border: 1px solid #486075;
            padding: 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            text-align: left;
            transition: background 0.2s;
        }
        button:hover {
            background-color: #2c3f50;
            border-color: #7094b3;
        }
        #feedback {
            font-size: 28px;
            font-weight: bold;
            text-align: center;
            margin-top: 20px;
            min-height: 40px;
        }
        .wrong {
            color: #ff4a4a;
            animation: shake 0.3s;
        }
        .correct {
            color: #4aff86;
        }
        #score-display {
            text-align: center;
            font-size: 20px;
            display: none;
        }
        .restart-btn {
            background-color: #486075;
            color: #e2f0fd;
            border: none;
            padding: 12px 25px;
            font-size: 18px;
            border-radius: 4px;
            cursor: pointer;
            margin: 20px auto 0 auto;
            display: block;
            text-align: center;
            font-weight: bold;
            transition: background 0.2s;
        }
        .restart-btn:hover {
            background-color: #5c7b96;
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
    </style>
</head>
<body>

<div class="quiz-container">
    <h1>Hollow Knight Quiz</h1>
    
    <div id="quiz-box">
        <!-- Question 1 -->
        <div class="question active" data-correct="2">
            <p>1. What is the name of the area where the game begins?</p>
            <div class="options">
                <button data-index="0">Dirtmouth</button>
                <button data-index="1">Greenpath</button>
                <button data-index="2">King's Pass</button>
                <button data-index="3">Forgotten Crossroads</button>
            </div>
        </div>

        <!-- Question 2 -->
        <div class="question" data-correct="1">
            <p>2. Who yells "Shaw!" during battle?</p>
            <div class="options">
                <button data-index="0">The Knight</button>
                <button data-index="1">Hornet</button>
                <button data-index="2">Zote the Mighty</button>
                <button data-index="3">Quirrel</button>
            </div>
        </div>

        <!-- Question 3 -->
        <div class="question" data-correct="3">
            <p>3. How many Geo does it cost to buy the Lumafly Lantern from Sly?</p>
            <div class="options">
                <button data-index="0">500</button>
                <button data-index="1">800</button>
                <button data-index="2">1200</button>
                <button data-index="3">1800</button>
            </div>
        </div>

        <!-- Question 4 -->
        <div class="question" data-correct="0">
            <p>4. Which character upgrades your Nail?</p>
            <div class="options">
                <button data-index="0">The Nailsmith</button>
                <button data-index="1">Sly</button>
                <button data-index="2">The Pale King</button>
                <button data-index="3">Salubra</button>
            </div>
        </div>

        <!-- Question 5 -->
        <div class="question" data-correct="2">
            <p>5. What substance gives the Knight the ability to double jump?</p>
            <div class="options">
                <button data-index="0">Mantis Claws</button>
                <button data-index="1">Crystal Heart</button>
                <button data-index="2">Monarch Wings</button>
                <button data-index="3">Isma's Tear</button>
            </div>
        </div>

        <!-- Question 6 -->
        <div class="question" data-correct="1">
            <p>6. How many total Dreamers must you defeat to unlock the Temple of the Black Egg?</p>
            <div class="options">
                <button data-index="0">2</button>
                <button data-index="1">3</button>
                <button data-index="2">4</button>
                <button data-index="3">5</button>
            </div>
        </div>

        <!-- Question 7 -->
        <div class="question" data-correct="0">
            <p>7. Who is the leader of the Grimm Troupe?</p>
            <div class="options">
                <button data-index="0">Troupe Master Grimm</button>
                <button data-index="1">The Radiance</button>
                <button data-index="2">Brumm</button>
                <button data-index="3">The Pale King</button>
            </div>
        </div>

        <!-- Question 8 -->
        <div class="question" data-correct="3">
            <p>8. What is the name of Zote the Mighty's weapon?</p>
            <div class="options">
                <button data-index="0">Pure Nail</button>
                <button data-index="1">Old Nail</button>
                <button data-index="2">Dream Nail</button>
                <button data-index="3">Lifeender</button>
            </div>
        </div>

        <!-- Question 9 -->
        <div class="question" data-correct="2">
            <p>9. Which charm allows you to generate SOUL over time without attacking?</p>
            <div class="options">
                <button data-index="0">Soul Catcher</button>
                <button data-index="1">Spell Twister</button>
                <button data-index="2">Kingsoul</button>
                <button data-index="3">Shaman Stone</button>
            </div>
        </div>

        <!-- Question 10 -->
        <div class="question" data-correct="0">
            <p>10. What is the ultimate endgame challenge area accessed through the Junk Pit?</p>
            <div class="options">
                <button data-index="0">Godhome</button>
                <button data-index="1">The Abyss</button>
                <button data-index="2">Colosseum of Fools</button>
                <button data-index="3">White Palace</button>
            </div>
        </div>

        <!-- Question 11 -->
        <div class="question" data-correct="1">
            <p>11. What is the Dung Defender's real name?</p>
            <div class="options">
                <button data-index="0">Hegemol</button>
                <button data-index="1">Ogrim</button>
                <button data-index="2">Ze'mer</button>
                <button data-index="3">Dryya</button>
            </div>
        </div>

        <!-- Question 12 -->
        <div class="question" data-correct="3">
            <p>12. How many total Arcane Eggs can be found throughout Hallownest?</p>
            <div class="options">
                <button data-index="0">2</button>
                <button data-index="1">3</button>
                <button data-index="2">4</button>
                <button data-index="3">5</button>
            </div>
        </div>

        <!-- Question 13 -->
        <div class="question" data-correct="0">
            <p>13. How many Geo are dropped when you defeat a Gorgeous Husk?</p>
            <div class="options">
                <button data-index="0">420</button>
                <button data-index="1">500</button>
                <button data-index="2">680</button>
                <button data-index="3">1000</button>
            </div>
        </div>

        <!-- Question 14 -->
        <div class="question" data-correct="2">
            <p>14. From what type of ancient creature was the Pale King born/transformed?</p>
            <div class="options">
                <button data-index="0">Void Entity</button>
                <button data-index="1">Ancient Spider</button>
                <button data-index="2">Wyrm</button>
                <button data-index="3">Root</button>
            </div>
        </div>

        <!-- Question 15 -->
        <div class="question" data-correct="1">
            <p>15. Which character mistakes the Knight for the Pale King after acquiring the King's Brand?</p>
            <div class="options">
                <button data-index="0">The White Lady</button>
                <button data-index="1">Bardoon</button>
                <button data-index="2">Elderbug</button>
                <button data-index="3">The Midwife</button>
            </div>
        </div>
    </div>

    <div id="feedback"></div>
    <div id="score-display"></div>
</div>

